@namespace ContextInterfaceApplications.Web.Components.Shared
@using ContextInterfaceApplications.Web.Models
@using ContextInterfaceApplications.Web.Services
@inject IActionComponentResolver ActionComponentResolver

<available-actions>
    @foreach (var action in Actions)
    {
        <DynamicComponent Type="ActionComponentResolver.Resolve(action.SourceComponent)"
                          Parameters="BuildParameters(action, ProjectionTarget.Agent)" />
    }
</available-actions>

@code {
    [Parameter, EditorRequired]
    public required IReadOnlyList<AuthoredActionContract> Actions { get; set; }

    private static IDictionary<string, object?> BuildParameters(AuthoredActionContract action, ProjectionTarget target) =>
        new Dictionary<string, object?>
        {
            ["Action"] = action,
            ["Target"] = target
        };
}
